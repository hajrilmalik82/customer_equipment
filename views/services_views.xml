<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_equipment_service_list" model="ir.ui.view">
        <field name="name">equipment.service.list</field>
        <field name="model">equipment.service</field>
        <field name="arch" type="xml">
            <list string="Service History">
                <field name="equipment_id"/>
                <field name="service_date"/>
                <field name="technician"/>
                <field name="cost" sum="Total"/>
            </list>
        </field>
    </record>

    <record id="view_equipment_service_form" model="ir.ui.view">
        <field name="name">equipment.service.form</field>
        <field name="model">equipment.service</field>
        <field name="arch" type="xml">
            <form string="Service">
                <sheet>
                    <group>
                        <group>
                            <field name="equipment_id"/>
                            <field name="service_date"/>
                        </group>
                        <group>
                            <field name="technician"/>
                            <field name="cost"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_equipment_service" model="ir.actions.act_window">
        <field name="name">Service History</field>
        <field name="res_model">equipment.service</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_customer_equipment_list" model="ir.ui.view">
        <field name="name">customer.equipment.list</field>
        <field name="model">customer.equipment</field>
        <field name="arch" type="xml">
            <list string="Customer Equipment">
                <field name="name"/>
                <field name="serial_number"/>
                <field name="customer_id"/>
                <field name="warranty_expired"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'active'" decoration-danger="state == 'retired'"/>
            </list>
        </field>
    </record>

    <record id="view_customer_equipment_form" model="ir.ui.view">
        <field name="name">customer.equipment.form</field>
        <field name="model">customer.equipment</field>
        <field name="arch" type="xml">
            <form string="Customer Equipment">
                <header>
                    <field name="state" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <div class="alert alert-warning text-center" role="alert" 
                         invisible="not warranty_expired or warranty_expired &gt;= current_date">
                        Masa garansi untuk equipment ini sudah habis.
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Nama Equipment"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="serial_number"/>
                            <field name="customer_id"/>
                        </group>
                        <group>
                            <field name="purchase_date"/>
                            <field name="warranty_expired"/>
                            <field name="total_cost" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Service History">
                            <field name="service_ids">
                                <list editable="bottom">
                                    <field name="service_date"/>
                                    <field name="technician"/>
                                    <field name="description"/>
                                    <field name="cost"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_customer_equipment" model="ir.actions.act_window">
        <field name="name">Customer Equipments</field>
        <field name="res_model">customer.equipment</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>